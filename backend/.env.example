# Backend environment configuration template.
# Copy this to backend/.env and fill in real values for your local setup.
# Never commit backend/.env (it's gitignored).

# ------------- App ----------------
# Default values shown — uncomment to override.
# APP_NAME=ai-data-analyst-platform
# APP_VERSION=0.1.0
ENVIRONMENT=dev

# ------------- Server -------------
HOST=0.0.0.0
PORT=8000
# Comma-separated, no spaces, no trailing slashes.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ------------- Uploads ------------
MAX_UPLOAD_MB=50
UPLOAD_ALLOWED_MIME_TYPES=text/csv,application/vnd.ms-excel

# ------------- Sessions -----------
SESSION_TTL_SECONDS=3600

# ------------- LLM keys -----------
# Leave blank for providers you don't use locally.
# Get a Groq key at https://console.groq.com/keys
GROQ_API_KEY=
# Get a Gemini key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Get an OpenAI key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ------------- Ollama -------------
OLLAMA_HOST=http://localhost:11434

# ------------- Default provider ---
# One of: groq, ollama, gemini, openai
DEFAULT_LLM_PROVIDER=groq
